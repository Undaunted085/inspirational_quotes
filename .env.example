# Copy this file to .env.local and fill in your own keys.
# Both services offer a free tier. Keys are read at build/runtime by Vite
# and, being a static client-side app, are visible in the browser bundle
# (fine for a personal project; see README/CLAUDE.md caveat).

# API Ninjas — https://api-ninjas.com/  (Quotes API)
VITE_QUOTES_API_KEY=

# Unsplash — https://unsplash.com/developers  (use the "Access Key")
VITE_UNSPLASH_ACCESS_KEY=
